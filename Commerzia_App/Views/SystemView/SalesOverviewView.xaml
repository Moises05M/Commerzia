<UserControl x:Class="Commerzia_App.Views.SystemView.SalesOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:components="clr-namespace:Commerzia_App.Styles.Components"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1100"
             FontFamily="Montserrat">

    <UserControl.Resources>
        <Style x:Key="FormCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.03" Direction="270" Color="#2B3674" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TableRowStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,0,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Sales Overview" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Manage your orders, invoices, and transaction history." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Height="40" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Filter" Width="12" Margin="0,0,8,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                        <TextBlock Text="Filter" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Height="40" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="CalendarDay" Width="12" Margin="0,0,8,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                        <TextBlock Text="Oct 2023" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>

                <Button Content="Export" Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="16,0" FontSize="13"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Create Order" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="20,0" FontSize="13"/>
        </Grid>

        <Grid Grid.Row="2" Margin="-10,0,-10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <components:DashboardCard Grid.Column="0" 
                                      Title="Monthly Revenue" Value="$45,231" 
                                      Trend="+15.3%" TrendIcon="ArrowTrendUp" TrendColor="{StaticResource SuccessBrush}" 
                                      Icon="Wallet" IconForeground="{StaticResource PrimaryBrandBrush}" IconBackground="{StaticResource ButtonSubtleBackgroundHover}"/>

            <components:DashboardCard Grid.Column="1" 
                                      Title="New Orders" Value="+546" 
                                      Trend="+5.2%" TrendIcon="ArrowTrendUp" TrendColor="{StaticResource SuccessBrush}" 
                                      Icon="BagShopping" IconForeground="#E83D8E" IconBackground="#FDEBF3"/>

            <components:DashboardCard Grid.Column="2" 
                                      Title="Pending Action" Value="12" 
                                      Trend="-1.2%" TrendIcon="ArrowTrendDown" TrendColor="{StaticResource DangerBrush}" 
                                      Icon="Clock" IconForeground="{StaticResource WarningBrush}" IconBackground="{StaticResource WarningBackgroundBrush}"/>

            <components:DashboardCard Grid.Column="3" 
                                      Title="Conversion Rate" Value="3.2%" 
                                      Trend="+2.4%" TrendIcon="ArrowTrendUp" TrendColor="{StaticResource SuccessBrush}" 
                                      Icon="ChartPie" IconForeground="{StaticResource SuccessBrush}" IconBackground="{StaticResource SuccessBackgroundBrush}"/>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource FormCardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="ORDER ID" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="2" Text="CLIENT" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="3" Text="DATE" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="4" Text="ITEMS" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="5" Text="AMOUNT" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="6" Text="STATUS" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="7" Text="ACTION" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                </Grid>

                <Separator Grid.Row="1" Background="{StaticResource DividerBrush}" Margin="-24,0,-24,16"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="#ORD-7652" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource ButtonSubtleBackgroundHover}" Margin="0,0,12,0">
                                    <fa:IconImage Icon="User" Width="14" Foreground="{StaticResource PrimaryBrandBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Marcus Johnson" Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="Oct 24, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="4" Text="3 Items" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="5" Text="$1,200.00" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="6" Background="{StaticResource SuccessBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Paid" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="7" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Separator Background="{StaticResource DividerBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="#ORD-7651" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="#FFFCE8" Margin="0,0,12,0">
                                    <fa:IconImage Icon="User" Width="14" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Li Wei" Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="Oct 23, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="4" Text="1 Item" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="5" Text="$850.50" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="6" Background="{StaticResource WarningBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Pending" Foreground="{StaticResource WarningBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="7" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Separator Background="{StaticResource DividerBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="#ORD-7649" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="#FDEBE9" Margin="0,0,12,0">
                                    <fa:IconImage Icon="User" Width="14" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Nia Teer" Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="Oct 22, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="4" Text="2 Items" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="5" Text="$120.00" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="6" Background="{StaticResource DangerBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Failed" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="7" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <TextBlock Text="Showing 1 to 3 of 142 entries" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Previous" Style="{StaticResource SecondaryButtonStyle}" Height="32" Padding="12,0" Margin="0,0,8,0" FontSize="13"/>

                        <Button Content="1" Style="{StaticResource PrimaryButtonStyle}" Height="32" Width="32" Padding="0" Margin="0,0,8,0" FontSize="13"/>
                        <Button Content="2" Style="{StaticResource SecondaryButtonStyle}" Height="32" Width="32" Padding="0" Margin="0,0,8,0" FontSize="13" BorderThickness="0"/>
                        <Button Content="3" Style="{StaticResource SecondaryButtonStyle}" Height="32" Width="32" Padding="0" Margin="0,0,8,0" FontSize="13" BorderThickness="0"/>
                        <TextBlock Text="..." VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <Button Content="12" Style="{StaticResource SecondaryButtonStyle}" Height="32" Width="32" Padding="0" Margin="0,0,8,0" FontSize="13" BorderThickness="0"/>

                        <Button Content="Next" Style="{StaticResource SecondaryButtonStyle}" Height="32" Padding="12,0" FontSize="13"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>