<UserControl x:Class="Commerzia_App.Views.SystemView.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:components="clr-namespace:Commerzia_App.Styles.Components"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1100"
             FontFamily="Montserrat">

    <UserControl.Resources>
        <Style x:Key="FormCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.03" Direction="270" Color="#2B3674" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TableRowStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Padding="4,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrandBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,0,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Purchases" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Manage purchase orders, suppliers, and inventory replenishment." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="-10,0,-10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <components:DashboardCard Grid.Column="0" 
                                      Title="Monthly Spend" Value="$45,200" 
                                      Trend="5%" TrendIcon="None" TrendColor="{StaticResource SuccessBrush}" 
                                      Icon="MoneyBillTransfer" IconForeground="{StaticResource PrimaryBrandBrush}" IconBackground="{StaticResource ButtonSubtleBackgroundHover}"/>

            <components:DashboardCard Grid.Column="1" 
                                      Title="Pending Approval" Value="12" 
                                      Trend="12" TrendIcon="None" TrendColor="{StaticResource WarningBrush}" 
                                      Icon="FileContract" IconForeground="{StaticResource WarningBrush}" IconBackground="{StaticResource WarningBackgroundBrush}"/>

            <components:DashboardCard Grid.Column="2" 
                                      Title="In Transit" Value="8" 
                                      Trend="28" TrendIcon="None" TrendColor="{StaticResource SuccessBrush}" 
                                      Icon="Truck" IconForeground="{StaticResource SuccessBrush}" IconBackground="{StaticResource SuccessBackgroundBrush}"/>

            <components:DashboardCard Grid.Column="3" 
                                      Title="Active Suppliers" Value="42" 
                                      Trend="Total" TrendIcon="None" TrendColor="{StaticResource TextSecondaryBrush}" 
                                      Icon="BuildingUser" IconForeground="#E83D8E" IconBackground="#FDEBF3"/>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Purchase Orders" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,32,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton Content="All (145)" Style="{StaticResource TabButtonStyle}" IsChecked="True"/>
                        <RadioButton Content="Pending (12)" Style="{StaticResource TabButtonStyle}"/>
                        <RadioButton Content="Received (130)" Style="{StaticResource TabButtonStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Filter" Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="16,0" Margin="0,0,12,0" FontSize="13"/>
                        <Button Content="Export" Style="{StaticResource SecondaryButtonStyle}" Height="40" Padding="16,0" Margin="0,0,12,0" FontSize="13"/>
                        <Button Content="Create Order" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="20,0" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <Separator Grid.Row="1" Background="{StaticResource DividerBrush}" Margin="-24,0,-24,16"/>

                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="ORDER ID" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="1" Text="SUPPLIER" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="2" Text="DATE CREATED" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="3" Text="EXPECTED DELIVERY" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="4" Text="TOTAL AMOUNT" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="5" Text="STATUS" Style="{StaticResource TableHeaderStyle}"/>
                    <TextBlock Grid.Column="6" Text="ACTIONS" Style="{StaticResource TableHeaderStyle}" HorizontalAlignment="Center"/>
                </Grid>

                <Separator Grid.Row="3" Background="{StaticResource DividerBrush}" Margin="-24,0,-24,16"/>

                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#PO-4092" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource ButtonSubtleBackgroundHover}" Margin="0,0,12,0">
                                    <TextBlock Text="T" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="TechSupplies Inc." Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="Oct 25, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="3" Text="Oct 30, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="4" Text="$12,450.00" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="5" Background="{StaticResource WarningBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Pending" Foreground="{StaticResource WarningBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="6" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Separator Background="{StaticResource DividerBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#PO-4091" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="#FDEBF3" Margin="0,0,12,0">
                                    <TextBlock Text="O" Foreground="#E83D8E" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Office Depot Ltd." Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="Oct 24, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="3" Text="Oct 28, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="4" Text="$3,200.50" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="5" Background="{StaticResource SuccessBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Received" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="6" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Separator Background="{StaticResource DividerBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#PO-4090" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource SuccessBackgroundBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="G" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Global Imports" Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="Oct 22, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="3" Text="Oct 27, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="4" Text="$8,900.00" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="5" Background="{StaticResource SuccessBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Received" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="6" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Separator Background="{StaticResource DividerBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#PO-4089" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource WarningBackgroundBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="F" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Fast Logistics" Style="{StaticResource TableRowStyle}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="Oct 20, 2023" Style="{StaticResource TableRowStyle}"/>
                            <TextBlock Grid.Column="3" Text="-" Style="{StaticResource TableRowStyle}" HorizontalAlignment="Center" Width="20"/>
                            <TextBlock Grid.Column="4" Text="$1,540.20" Style="{StaticResource TableRowStyle}" FontWeight="SemiBold"/>

                            <Border Grid.Column="5" Background="{StaticResource DangerBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Cancelled" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <Button Grid.Column="6" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Ellipsis" Width="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>
    </Grid>
</UserControl>