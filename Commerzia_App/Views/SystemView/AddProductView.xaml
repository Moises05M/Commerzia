<UserControl x:Class="Commerzia_App.Views.SystemView.AddProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:vm="clr-namespace:Commerzia_App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1100"
             FontFamily="Montserrat"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.DataContext>
        <vm:AddProductViewModel/>
    </UserControl.DataContext>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Add New Product" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Create a new item in your inventory." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,16,0" Command="{Binding CancelCommand}" />
                <Button Content="Save Product" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6.5*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="3.5*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <Border Style="{StaticResource FormCardStyle}">
                        <StackPanel>
                            <TextBlock Text="General Information" Style="{StaticResource CardTitleStyle}"/>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Product Name *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource CustomTextBoxStyle}" 
                                         Tag="e.g. Nike Air Max 270" 
                                         Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource CustomTextBoxStyle}" 
                                         Height="120" TextWrapping="Wrap" AcceptsReturn="True" 
                                         VerticalContentAlignment="Top" Padding="16,12" 
                                         Tag="Enter product details..." 
                                         Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource FormCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Media (Image)" Style="{StaticResource CardTitleStyle}"/>

                            <Grid Height="180" Cursor="Hand">
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding UploadImageCommand}"/>
                                </Grid.InputBindings>
                                <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="8" />
                                <Rectangle Stroke="{StaticResource DividerBrush}" StrokeThickness="2" StrokeDashArray="4 4" RadiusX="8" RadiusY="8"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource SurfaceBrush}" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000"/>
                                        </Border.Effect>
                                        <fa:IconImage Icon="CloudArrowUp" Foreground="{StaticResource PrimaryBrandBrush}" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Run Text="Click to upload image" Foreground="{StaticResource PrimaryBrandBrush}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <Border Style="{StaticResource FormCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Pricing &amp; Inventory" Style="{StaticResource CardTitleStyle}"/>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Base Price ($) *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource CustomTextBoxStyle}" 
                                         Tag="0.00" 
                                         Text="{Binding PrecioVenta, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="SKU / Barcode *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource CustomTextBoxStyle}" 
                                         Tag="NK-2023-001" 
                                         Text="{Binding CodigoSKU, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Initial Quantity" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource CustomTextBoxStyle}" 
                                         Tag="0" 
                                         Text="{Binding InitialStock, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource FormCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Organization" Style="{StaticResource CardTitleStyle}"/>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Status *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource CustomComboBoxStyle}" 
                                          ItemsSource="{Binding Statuses}" 
                                          SelectedValue="{Binding SelectedStatusId}" 
                                          DisplayMemberPath="Nombre" 
                                          SelectedValuePath="IdEstado" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Category *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource CustomComboBoxStyle}" 
                                          ItemsSource="{Binding Categories}" 
                                          SelectedValue="{Binding SelectedCategoryId}" 
                                          DisplayMemberPath="Nombre" 
                                          SelectedValuePath="IdCategoria" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Brand / Vendor *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource CustomComboBoxStyle}" 
                                          ItemsSource="{Binding Brands}" 
                                          SelectedValue="{Binding SelectedBrandId}" 
                                          DisplayMemberPath="Nombre" 
                                          SelectedValuePath="IdMarca" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>