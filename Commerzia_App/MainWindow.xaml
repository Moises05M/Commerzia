<Window x:Class="Commerzia_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Commerzia_App" 
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" 
            Background="{StaticResource SurfaceBrush}" 
            BorderBrush="{StaticResource DividerBrush}" 
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,32,24,32">
                    <fa:IconImage Icon="Cube" Width="28" Height="28" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,0,12,0"/>
                    <TextBlock Text="Commerzia" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="12,0,12,0" BorderThickness="0">
                    <StackPanel>

                        <RadioButton Style="{StaticResource MenuNavigationButtonStyle}" GroupName="MenuGroup" IsChecked="True">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="TableCellsLarge" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MenuNavigationButtonStyle}" GroupName="MenuGroup">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="CartShopping" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Sales" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MenuNavigationButtonStyle}" GroupName="MenuGroup">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="BagShopping" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Purchases" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MenuNavigationButtonStyle}" GroupName="MenuGroup">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Users" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Clients" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MenuNavigationButtonStyle}" GroupName="MenuGroup">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Box" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Inventory" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="12,0,12,24">
                    <RadioButton Style="{StaticResource MenuNavigationButtonStyle}" GroupName="MenuGroup">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Gear" Width="18" Height="18" Margin="0,0,16,0"
                                      Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="Transparent">

            <TextBlock Text="Contenido Principal" 
                   FontSize="28" 
                   FontWeight="SemiBold" 
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   Opacity="0.4"/>

        </Grid>
    </Grid>

</Window>
