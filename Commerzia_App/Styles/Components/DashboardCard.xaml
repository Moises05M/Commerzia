<UserControl x:Class="Commerzia_App.Styles.Components.DashboardCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             x:Name="CardRoot">
    
    <Border Background="{StaticResource SurfaceBrush}" 
            CornerRadius="16" 
            Padding="20" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.04" Direction="270" Color="#2B3674" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" 
                        Background="{Binding IconBackground, ElementName=CardRoot}">
                    <fa:IconImage Icon="{Binding Icon, ElementName=CardRoot}" 
                                  Foreground="{Binding IconForeground, ElementName=CardRoot}" 
                                  Width="20" Height="20" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,0,0">
                    <fa:IconImage Icon="{Binding TrendIcon, ElementName=CardRoot}" 
                                  Foreground="{Binding TrendColor, ElementName=CardRoot}" 
                                  Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Trend, ElementName=CardRoot}" 
                               Foreground="{Binding TrendColor, ElementName=CardRoot}" 
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="2" 
                       Text="{Binding Value, ElementName=CardRoot}" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}" 
                       Margin="0,20,0,4"/>

            <TextBlock Grid.Row="3" 
                       Text="{Binding Title, ElementName=CardRoot}" 
                       FontSize="14" FontWeight="Medium"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Grid>
    </Border>
</UserControl>